rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Coleção principal da aplicação
    match /orcamentoPiso/{document} {

      // Leitura pública permitida (o app não usa Firebase Authentication)
      allow read: if true;

      // Gravação permitida apenas de origens confiáveis.
      // Como o app usa autenticação própria (sem Firebase Auth), a gravação é
      // permitida a qualquer cliente. Restrinja por IP ou outro mecanismo
      // se desejar proteger melhor em produção.
      allow write: if true;
    }

    // Bloqueia todo o resto por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
